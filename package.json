{
  "name": "daily-financial-coach",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bump:playwright-image": "PLAYWRIGHT_VERSION=$(pnpm ls @playwright/test --json --depth=0 | jq -r '.[0].devDependencies[\"@playwright/test\"].version') && sed -i -E \"s|(mcr\\.microsoft\\.com/playwright:)v[0-9]+\\.[0-9]+\\.[0-9]+(@sha256:[a-f0-9]+)? +# ratchet:mcr\\.microsoft\\.com/playwright:v[0-9]+\\.[0-9]+\\.[0-9]+|\\1v$PLAYWRIGHT_VERSION\\2 # ratchet:mcr.microsoft.com/playwright:v$PLAYWRIGHT_VERSION|\" .github/workflows/*.yml",
    "bump:biome-schema": "BIOME_VERSION=$(pnpm ls @biomejs/biome --json --depth=0 | jq -r '.[0].devDependencies[\"@biomejs/biome\"].version') && pnpx @biomejs/biome@$BIOME_VERSION migrate --write",
    "pwa:assets": "node scripts/generate-pwa-assets.mjs",
    "prebuild": "pnpm run pwa:assets",
    "build": "vite build",
    "bundle": "pnpm dlx vite-bundle-visualizer",
    "coverage": "vitest run --coverage --silent --exclude 'e2e'",
    "coverage:ui": "vitest --ui --open --coverage --silent --exclude 'e2e'",
    "lint": "biome check --fix",
    "lint:packages": "pnpm dedupe",
    "schema": "pnpm dlx generate-schema ./docs/guitos-sample.json",
    "serve": "vite preview",
    "start": "vite",
    "test": "pnpm test:unit --run && pnpm test:e2e",
    "test:unit": "vitest --typecheck --exclude 'e2e'",
    "test:e2e": "playwright test --reporter=list --project chromium",
    "test:e2e:mobile": "playwright test --reporter=list --project 'Mobile Chrome'",
    "test:e2e:mobile:ui": "playwright test --ui --project 'Mobile Chrome'",
    "test:e2e:ui": "playwright test --ui --project chromium",
    "knip": "pnpm dlx knip"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slider": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "big.js": "7.0.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "immer": "11.1.8",
    "localforage": "1.10.0",
    "lucide-react": "0.469.0",
    "motion": "12.40.0",
    "next-themes": "0.4.4",
    "papaparse": "5.5.3",
    "react": "19.2.6",
    "react-currency-input-field": "4.0.5",
    "react-dom": "19.2.6",
    "react-hotkeys-hook": "5.3.2",
    "react-icons": "5.6.0",
    "recharts": "3.8.1",
    "sonner": "1.7.1",
    "tailwind-merge": "2.6.0",
    "use-immer": "0.11.0",
    "use-undo": "1.2.0",
    "wouter": "3.10.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@biomejs/biome": "2.4.16",
    "@faker-js/faker": "10.4.0",
    "@playwright/test": "1.60.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/big.js": "7.0.0",
    "@types/node": "25.9.1",
    "@types/papaparse": "5.5.2",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "@vitest/ui": "4.1.7",
    "browserslist-config-baseline": "0.5.0",
    "console-fail-test": "0.6.1",
    "happy-dom": "20.9.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "6.0.3",
    "vite": "^8.0.11",
    "vite-plugin-pwa": "1.3.0",
    "vite-plugin-sri3": "2.0.0",
    "vitest": "4.1.7",
    "vitest-when": "0.10.0",
    "workbox-window": "7.4.1"
  },
  "browserslist": {
    "production": "defaults",
    "development": [
      "extends browserslist-config-baseline"
    ]
  }
}
